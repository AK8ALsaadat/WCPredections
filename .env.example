# =============================================================================
# REQUIRED — Supabase PostgreSQL (Prisma connection)
# =============================================================================
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction" pooler URL for serverless, or direct connection for local dev.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# =============================================================================
# REQUIRED — Session encryption (min 32 characters)
# =============================================================================
# Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars-long"
# كم يوم يبقى المستخدم مسجّل (افتراضي 365)
SESSION_MAX_AGE_DAYS="365"

# =============================================================================
# OPTIONAL — Supabase project (for future client-side features, NOT used for auth)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# =============================================================================
# OPTIONAL — Admin access (comma-separated usernames)
# =============================================================================
ADMIN_USERNAMES="admin"

# =============================================================================
# OPTIONAL — External Football API (choose one provider)
# =============================================================================
# Provider: "api-football" | "football-data"
FOOTBALL_API_PROVIDER="api-football"

# API-Football (https://www.api-football.com/)
API_FOOTBALL_KEY="your-api-football-key"
API_FOOTBALL_BASE_URL="https://v3.football.api-sports.io"
# تشكيلة محتملة من آخر مباراة (يتطلب API_FOOTBALL_KEY)
LINEUP_USE_API_FOOTBALL="true"

# Football-Data.org (https://www.football-data.org/)
FOOTBALL_DATA_API_KEY="your-football-data-key"
FOOTBALL_DATA_BASE_URL="https://api.football-data.org/v4"
# تشكيلة متوقعة من قائمة المنتخب / آخر مباراة (يتطلب FOOTBALL_DATA_API_KEY)
LINEUP_USE_FOOTBALL_DATA="true"

# =============================================================================
# OPTIONAL — App URL (for production)
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
